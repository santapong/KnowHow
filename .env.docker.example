# Copy to .env.docker and fill in.
# `docker compose up` reads .env.docker (referenced from docker-compose.yml).

# --- Path 1: hosted Supabase project ---
# From Supabase Studio -> Project Settings -> API:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Public URL the browser sees. For local Docker, leave it as localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Path 2: local Supabase via CLI (`npx supabase start`) ---
# Replace the URL above with the one printed by the CLI, prefixed with
# host.docker.internal so the container can reach the host:
#
# NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from `supabase status`>
# SUPABASE_SERVICE_ROLE_KEY=<service_role key from `supabase status`>
#
# (Apple Silicon / Linux: host.docker.internal is mapped via extra_hosts
#  in docker-compose.yml; no extra setup needed.)

# Optional: change the host port mapping
# PORT=3000
