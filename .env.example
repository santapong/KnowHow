# Supabase (Phase 1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL — used for OAuth callbacks. Use http://localhost:3000 in dev,
# your Vercel preview URL on previews, and your production URL on prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (Phase 10 — billing)
# Create products in your Stripe dashboard with recurring prices, then paste
# the price IDs (price_…) here. Leave all blank to run without billing.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=
