# LLM Provider: "openai", "anthropic", "ollama", or any OpenAI-compatible name
LLM_PROVIDER=openai

# API credentials (use whichever matches your provider)
API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...    # Alternative for Anthropic
# OPENAI_API_KEY=sk-...           # Legacy support

# API endpoint (auto-detected per provider, override if needed)
# API_BASE_URL=https://api.openai.com/v1
# API_BASE_URL=http://localhost:11434       # Ollama
# API_BASE_URL=https://api.together.xyz/v1  # Together AI (OpenAI-compatible)
# API_BASE_URL=https://api.groq.com/openai/v1  # Groq (OpenAI-compatible)

# Models (auto-detected per provider, override if needed)
# LLM_MODEL=gpt-4o-mini              # OpenAI
# LLM_MODEL=claude-sonnet-4-20250514  # Anthropic
# LLM_MODEL=llama3.2                  # Ollama
# EMBEDDING_MODEL=text-embedding-3-small  # OpenAI
# EMBEDDING_MODEL=nomic-embed-text        # Ollama

# Document processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# RAG settings
HYDE_NUM_HYPOTHETICALS=3
TOP_K=5
